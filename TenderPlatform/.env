# Настройки базы данных (для разработки SQLite)
DATABASE_URL=sqlite:///./tender.db

# Безопасность
SECRET_KEY=change_this_secret_key_super_secure_2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Почта (замените на свои данные)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com

# Загрузка файлов
UPLOAD_DIR=uploads
MAX_FILE_SIZE=52428800  # 50 MB
ALLOWED_EXTENSIONS=[".pdf", ".doc", ".docx", ".xls", ".xlsx", ".jpg", ".png"]

# Срок действия ссылки-приглашения (часы)
INVITE_TOKEN_EXPIRE_HOURS=72
