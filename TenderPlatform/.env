# Настройки базы данных (Postgres)
# При деплое на сервер заменим localhost на реальные данные
DATABASE_URL=sqlite:///./tender.db

# Секретный ключ для токенов безопасности (сгенерируй случайную строку в будущем)
SECRET_KEY=super_secret_key_change_me_12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Настройки для отправки почты (пока заглушки)
MAIL_USERNAME=admin@example.com
MAIL_PASSWORD=secret
MAIL_FROM=admin@tender-platform.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
